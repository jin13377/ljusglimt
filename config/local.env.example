# Kopiera filen till local.env och fyll i ditt publika Google Web Client ID.
GOOGLE_CLIENT_ID=din-klient.apps.googleusercontent.com

# Sätt true bakom en proxy som själv skriver över CF-Connecting-IP och
# X-Forwarded-Proto. Lämna false vid direkt lokal körning.
GLIMT_TRUST_PROXY=false

# Sätt true på en permanent HTTPS-publicering.
GLIMT_SECURE_COOKIES=false
